---
import BaseLayout from "./BaseLayout.astro";
import ServiceFeature from "../components/ServiceFeature.astro";
import HowItWorks from "../components/HowItWorks.astro";
import FaqItem from "../components/FaqItem.astro";
import CtaBand from "../components/CtaBand.astro";
import type { Service } from "../data/services";

interface Props {
  service: Service;
}

const { service } = Astro.props;
---

<BaseLayout
  title={`${service.title} - iStream | Hawkes Bay`}
  description={`${service.subtitle} Professional ${service.title.toLowerCase()} services in Hawkes Bay, New Zealand.`}
>
  <!-- Service Hero -->
  <section class="film-grain relative flex min-h-[60vh] items-end overflow-hidden pb-16">
    <img
      src={service.imageUrl}
      alt=""
      role="presentation"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-background via-background/80 to-background/30"></div>
    <div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
      <div class="mx-auto mb-4 h-1 w-12 rounded-full" style={`background: ${service.accentColor};`}></div>
      <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl" style="letter-spacing: -0.01em;">
        {service.title}
      </h1>
      <p class="mt-4 text-lg text-text-secondary">{service.subtitle}</p>
      <a
        href="/contact"
        class="mt-8 inline-block rounded-full px-8 py-3 text-sm font-semibold text-white shadow-lg transition-all hover:shadow-xl"
        style={`background: ${service.accentColor}; box-shadow: 0 0 30px ${service.accentColor}30;`}
      >
        Get a Quote for {service.shortTitle}
      </a>
    </div>
  </section>

  <!-- What We Offer -->
  <section class="mx-auto max-w-5xl px-6 py-16">
    <h2 class="text-2xl font-semibold tracking-tight text-text-primary sm:text-3xl">
      What We Offer
    </h2>
    <div class="mt-10 grid grid-cols-1 gap-8 sm:grid-cols-2">
      {service.features.map((f) => (
        <ServiceFeature icon={f.icon} title={f.title} description={f.description} accentColor={service.accentColor} />
      ))}
    </div>
  </section>

  <!-- How It Works -->
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h2 class="text-2xl font-semibold tracking-tight text-text-primary sm:text-3xl">
      How It Works
    </h2>
    <div class="mt-10">
      <HowItWorks steps={service.howItWorks} accentColor={service.accentColor} />
    </div>
  </section>

  <!-- Popular For -->
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h2 class="text-2xl font-semibold tracking-tight text-text-primary sm:text-3xl">
      Popular For
    </h2>
    <div class="mt-6 flex flex-wrap gap-3">
      {service.popularFor.map((tag) => (
        <span class="rounded-full px-4 py-2 text-sm font-medium text-white" style={`background: ${service.accentColor}20; border: 1px solid ${service.accentColor}40; color: ${service.accentColor};`}>
          {tag}
        </span>
      ))}
    </div>
  </section>

  <!-- Pricing -->
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h2 class="text-2xl font-semibold tracking-tight text-text-primary sm:text-3xl">
      Indicative Pricing
    </h2>
    <div class="mt-8 rounded-2xl border border-border bg-surface/50 p-8">
      <div class="flex items-baseline gap-2">
        <span class="text-4xl font-bold text-white">From {service.pricing.from}</span>
        <span class="text-sm text-text-secondary">+ GST</span>
      </div>
      <p class="mt-4 text-sm text-text-secondary leading-relaxed">
        {service.pricing.note}
      </p>
      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <a
          href="/contact"
          class="rounded-full px-8 py-3 text-center text-sm font-semibold text-white transition-all hover:shadow-lg"
          style={`background: ${service.accentColor}; box-shadow: 0 0 20px ${service.accentColor}30;`}
        >
          Get an Exact Quote
        </a>
        <a
          href="tel:0223806280"
          class="rounded-full border border-border px-8 py-3 text-center text-sm font-semibold text-text-secondary transition-colors hover:border-accent/60 hover:text-white"
        >
          Call to Discuss
        </a>
      </div>
      <p class="mt-4 text-xs text-text-secondary/60">
        Every event is different. Contact us for a personalised quote tailored to your venue, requirements, and budget.
      </p>
    </div>
  </section>

  <!-- FAQs -->
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h2 class="text-2xl font-semibold tracking-tight text-text-primary sm:text-3xl">
      Frequently Asked Questions
    </h2>
    <div class="mt-8 space-y-4">
      {service.faqs.map((faq, i) => (
        <FaqItem question={faq.question} answer={faq.answer} id={`${service.slug}-${i}`} />
      ))}
    </div>
  </section>

  <CtaBand buttonText={`Get a Quote for ${service.shortTitle}`} />
</BaseLayout>

<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll("[data-faq-toggle]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const panel = btn.parentElement?.querySelector("[data-faq-panel]") as HTMLElement | null;
        const icon = btn.querySelector("[data-faq-icon]") as HTMLElement | null;
        if (!panel || !icon) return;

        const isOpen = btn.getAttribute("aria-expanded") === "true";

        if (isOpen) {
          panel.style.maxHeight = "0";
          btn.setAttribute("aria-expanded", "false");
          icon.style.transform = "rotate(0deg)";
        } else {
          panel.style.maxHeight = panel.scrollHeight + "px";
          btn.setAttribute("aria-expanded", "true");
          icon.style.transform = "rotate(45deg)";
        }
      });
    });
  });
</script>
